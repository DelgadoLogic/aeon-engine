+// Aeon: Add per-session noise to canvas pixel output
+// Called after every drawImage/fillRect/putImageData
+void HTMLCanvasElement::AeonAddCanvasNoise(unsigned char* pixels, size_t len) {
+  for (size_t i = 0; i < len; i += 4) {
+    int8_t noise = AeonFingerprintSeed::GetCanvasNoise(i);
+    pixels[i]   = std::clamp(pixels[i]   + noise, 0, 255);  // R
+    pixels[i+1] = std::clamp(pixels[i+1] + noise, 0, 255);  // G
+    pixels[i+2] = std::clamp(pixels[i+2] + noise, 0, 255);  // B
+    // Alpha untouched
+  }
+}

