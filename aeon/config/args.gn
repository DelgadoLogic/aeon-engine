# =============================================================================
# Aeon Browser — Sovereign Build Configuration
# Generated by AeonDNA policy engine
# Apply with: gn gen out/Aeon --args="$(cat aeon/config/args.gn)"
# =============================================================================

# ── Target OS / Architecture ──────────────────────────────────────────────────
target_os   = "win"
target_cpu  = "x64"
is_debug    = false
is_official_build = true
is_component_build = false

# ── Strip ALL Google identity and cloud endpoints ─────────────────────────────
google_api_key            = ""
google_default_client_id  = ""
google_default_client_secret = ""
# Explicitly prevent fallback to embedded keys
use_official_google_api_keys = false

# ── Disable Google-cloud AI features (Gemini, Auto Browse, Nano Banana) ───────
enable_extensions_core = true      # Keep — needed for AeonExtensions
enable_google_now = false          # Google Now / Discover feed — STRIPPED
safe_browsing_mode = 0             # 0=off; AeonShield replaces server-side model
enable_reporting = false           # No crash/UMA reporting to Google
enable_background_mode = true      # Keep — needed for AeonAgent tray

# ── Privacy: remove Google sync, sign-in, and profiles ───────────────────────
enable_signin = false              # No Google account required
sync_driver = false                # No Chrome sync
enable_supervised_users = false    # No Family Link
enable_print_preview = true        # Keep — neutral feature

# ── Strip Google services that phone home ─────────────────────────────────────
enable_hangout_services_extension = false  # Google Meet integration
enable_service_worker_default_enabled = true  # Keep — standard web platform
enable_basic_printing = true
enable_mdns = false                # AeonCast handles mDNS natively
enable_reading_list = true         # Keep — offline-first, privacy-neutral

# ── AeonDNA compliance flags ──────────────────────────────────────────────────
aeon_sovereign_updates = true      # Enables AeonHive P2P update channel
aeon_local_ai = true               # Enables AeonAgent (Whisper/LLM local only)
aeon_shield = true                 # Enables AeonShield privacy enforcement layer
aeon_voice = true                  # Enables AeonVoice (local Whisper STT)
aeon_translate = true              # Enables AeonTranslate (CTranslate2 local)
aeon_spell = true                  # Enables AeonSpell (Hunspell sovereign dicts)
aeon_cast = true                   # Enables AeonCast (sovereign mDNS/Cast V2)

# ── Build performance ─────────────────────────────────────────────────────────
symbol_level    = 1
blink_symbol_level = 0
v8_symbol_level = 0
use_thin_lto    = true
use_lld         = true
